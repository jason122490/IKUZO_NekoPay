# Copy to .env and fill in. NEVER commit .env.
ENV=dev

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./data/nekopay.db

# --- App secrets (generate with: python -c "import secrets; print(secrets.token_urlsafe(48))") ---
SECRET_KEY=change-me-session-signing-key
# Fernet key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
SECRET_ENCRYPTION_KEY=change-me-fernet-key

# --- Shared NekoPay account (server-side sync only; rotate the real password!) ---
NEKOPAY_BASE_URL=https://shironekoya.net
NEKOPAY_EMAIL=shared-account@example.com
NEKOPAY_PASSWORD=change-me
NEKOPAY_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0 Safari/537.36
# Optional: route shironekoya.net requests through a home/residential proxy so
# Cloudflare sees a trusted IP (cloud datacenter IPs get blocked). Empty = direct.
# Example (Raspberry Pi over Tailscale): NEKOPAY_PROXY=http://100.x.y.z:8888
NEKOPAY_PROXY=

# --- Sync ---
RUN_SCHEDULER=true
SYNC_INTERVAL_SECONDS=3600
APP_TIMEZONE=Asia/Taipei

# --- NT$ <-> points (1 point = N NT$; admin can change in-app) ---
DEFAULT_RATE_NT_PER_POINT=10

# --- Sessions ("remember me": log in once, cookie auto-login afterwards) ---
SESSION_TTL_HOURS=720

# --- Bootstrap admin (created on first startup if absent) ---
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=change-me-admin
